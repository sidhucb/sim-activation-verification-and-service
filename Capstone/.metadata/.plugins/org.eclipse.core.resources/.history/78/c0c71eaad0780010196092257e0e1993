package com.cardactivation;

import io.github.resilience4j.circuitbreaker.annotation.CircuitBreaker;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.nio.file.StandardCopyOption;
import java.util.Optional;

@Service

public class CardActivationServiceInterface {
    private static final String UPLOAD_DIR = "upload";

    @Autowired
    
    private CardActivationRepository repository;

    // Save file path and initial record
    public CardActivationEntity saveFilePath(String userName, String fileName, String filePath) {
    	CardActivationEntity entity = new CardActivationEntity();
        entity.setUserName(userName);
        entity.setFileName(fileName);
        entity.setFilePath(filePath);
        return repository.save(entity);
    }

    // Upload File & Create record
    public CardActivationEntity uploadAndSaveFile(MultipartFile file, String userName) throws IOException {
        Path uploadDir = Paths.get(UPLOAD_DIR);
        if (!Files.exists(uploadDir)) {
            Files.createDirectories(uploadDir);
        }
        Path filePath = uploadDir.resolve(file.getOriginalFilename());
        Files.copy(file.getInputStream(), filePath, StandardCopyOption.REPLACE_EXISTING);

        return saveFilePath(userName, file.getOriginalFilename(), filePath.toString());
    }

    // Simulated OCR Extraction - will "extract" dummy data for demo
    @CircuitBreaker(name = "ocrService", fallbackMethod = "ocrFallback")
    public String extractedText(Long id) {
        Optional<CardActivationEntity> opt = repository.findById(id);
        if (opt.isEmpty()) {
            return "Record not found ,Try to upload different file";
        }
        CardActivationEntity entity = opt.get();

        // Simulate OCR: just fake extracting text from filename
        String extractedText = "ExtractedNameFromID_" + entity.getFileName();

        entity.setExtractedText(extractedText);
        repository.save(entity);

        return extractedText;
    }

    // Fallback if OCR fails
    public String ocrFallback(Long id, Throwable t) {
        return "OCR service is currently unavailable. Please try again later.";
    }

    // Simulated KYC Verification (typically complex, here just toggles status)
    public String findByverifyKyc(Long id) {
        Optional<CardActivationEntity> opt = repository.findById(id);
        if (opt.isEmpty()) {
            return "Record not found";
        }
        CardActivationEntity entity = opt.get();

        // Simple simulation: if OCR text exists, approve KYC, else reject
        if (entity.getExtractedText() != null && !entity.getExtractedText().isEmpty()) {
            entity.setKycStatus("Completed");
        } else {
            entity.setKycStatus("Rejected");
        }

        repository.save(entity);
        return "KYC Status: " + entity.getKycStatus();
    }

    // Get by username
    public CardActivationEntity getByName(String userName) {
        return repository.findByUserName(userName).orElse(null);
    }
}
