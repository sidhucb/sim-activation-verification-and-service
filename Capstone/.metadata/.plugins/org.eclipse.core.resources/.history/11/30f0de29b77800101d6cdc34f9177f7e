package com.cardactivation;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;

@RestController
@RequestMapping("/card")
public class CardActivationController {

	    @Autowired
	    private CardActivationServiceInterface service;

	    // Upload with userName param added
	    @PostMapping("/upload")
	    public CardActivationEntity uploadFile(@RequestParam("file") MultipartFile file,
	                                          @RequestParam("userName") String userName) throws IOException {
	        return service.uploadAndSaveFile(file, userName);
	    }

	    // Extract text (OCR simulation) by ID
	    @GetMapping("/extract/{id}")
	    public String extractText(@PathVariable Long id) {
	        return service.extractText(id);
	    }

	    // Verify KYC - simulate
	    @PostMapping("/verifyKyc/{id}")
	    public String verifyKyc(@PathVariable Long id) {
	        return service.verifyKyc(id);
	    }
	   

	    // Get record by name
	    @GetMapping("/get/{name}")
	    public CardActivationEntity getByName(@PathVariable String userName) {
	        return service.getByName(userName);
	    }
	}
